# Local Docker Postgres (see docker-compose.yml — port 5433 to avoid clashing with a host install)
DATABASE_URL="postgresql://postgres:password@localhost:5433/tinder_movies"

# Neon (serverless Postgres) — use the -pooler endpoint and bump connect_timeout to survive cold starts:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15&pool_timeout=15"

JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
TMDB_API_KEY="your-tmdb-api-key-from-themoviedb.org"
PORT=3001
FRONTEND_URL="http://localhost:5173"
